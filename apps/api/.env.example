# --- Supabase ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service role key (server-side ONLY — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Anon/public key (used to verify user JWTs)
SUPABASE_ANON_KEY=
# --- Booking behaviour ---
# Minutes a client "pending" hold blocks a slot before auto-expiring
PENDING_HOLD_MINUTES=30

# --- Server ---
PORT=3000
# Comma-separated list of allowed CORS origins for the web app
CORS_ORIGINS=http://localhost:4200
